library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity interface_leds_botoes is
    port (
        clock        : in  std_logic;
        reset        : in  std_logic;
        iniciar      : in  std_logic;
        resposta     : in  std_logic;
        ligado       : out std_logic;
        estimulo     : out std_logic;
        erro         : out std_logic;
        pronto       : out std_logic;
        pulso        : out std_logic;
        display0     : out std_logic_vector(6 downto 0);
        display1     : out std_logic_vector(6 downto 0);
        display2     : out std_logic_vector(6 downto 0);
        display3     : out std_logic_vector(6 downto 0);
        db_estado    : out std_logic_vector(6 downto 0)
    );
end entity;

architecture structural of interface_leds_botoes is

    signal s_zera, s_conta, s_fim_atraso : std_logic;
    signal s_estado                      : std_logic_vector(3 downto 0);
    signal s_tempo                       : std_logic_vector(13 downto 0);
    signal s_dig0, s_dig1                : std_logic_vector(3 downto 0);
    signal s_dig2, s_dig3                : std_logic_vector(3 downto 0);

begin

    CTRL_INST: entity work.controlador
        port map (
            clock       => clock,
            reset       => reset,
            iniciar     => iniciar,
            resposta    => resposta,
            fim_atraso  => s_fim_atraso,
            zeraCont    => s_zera,
            contaCont   => s_conta,
            ligado      => ligado,
            estimulo    => estimulo,
            erro        => erro,
            pronto      => pronto,
            pulso       => pulso,
            db_estado   => s_estado,
            valor_tempo => s_tempo
        );

    ATRASO_INST: entity work.cont10
        port map (
            clock  => clock,
            clear  => s_zera,
            enable => s_conta,
            Q      => open,
            RCO    => s_fim_atraso
        );

    process(s_tempo)
        variable v_tempo : integer;
        variable v_d0, v_d1, v_d2, v_d3 : integer;
    begin
        v_tempo := to_integer(unsigned(s_tempo));
        v_d0 := v_tempo mod 10;
        v_d1 := (v_tempo / 10) mod 10;
        v_d2 := (v_tempo / 100) mod 10;
        v_d3 := (v_tempo / 1000) mod 10;

        s_dig0 <= std_logic_vector(to_unsigned(v_d0, 4));
        s_dig1 <= std_logic_vector(to_unsigned(v_d1, 4));
        s_dig2 <= std_logic_vector(to_unsigned(v_d2, 4));
        s_dig3 <= std_logic_vector(to_unsigned(v_d3, 4));
    end process;

    DISP0_INST: entity work.hex7seg
        port map (
            hex     => s_dig0,
            display => display0
        );

    DISP1_INST: entity work.hex7seg
        port map (
            hex     => s_dig1,
            display => display1
        );

    DISP2_INST: entity work.hex7seg
        port map (
            hex     => s_dig2,
            display => display2
        );

    DISP3_INST: entity work.hex7seg
        port map (
            hex     => s_dig3,
            display => display3
        );

    DB_ESTADO_INST: entity work.hex7seg
        port map (
            hex     => s_estado,
            display => db_estado
        );

end architecture structural;
